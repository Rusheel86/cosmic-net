# =============================================================================
# .env.example
# Purpose: Template for environment variables required by Cosmic-Net
# Instructions: Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# IllustrisTNG API Authentication
# Get your API key at: https://www.tng-project.org/users/register/
# Required for: tng data source
# -----------------------------------------------------------------------------
TNG_API_KEY=your_tng_api_key_here

# -----------------------------------------------------------------------------
# Weights & Biases Authentication
# Get your API key at: https://wandb.ai/authorize
# Required for: experiment tracking and logging
# -----------------------------------------------------------------------------
WANDB_API_KEY=your_wandb_api_key_here

# Optional: W&B entity (username or team name)
# If not set, defaults to your personal account
WANDB_ENTITY=

# -----------------------------------------------------------------------------
# Hugging Face Authentication (optional)
# Get your token at: https://huggingface.co/settings/tokens
# Required for: camels_hf data source (if dataset is gated)
# -----------------------------------------------------------------------------
HF_TOKEN=your_huggingface_token_here

# -----------------------------------------------------------------------------
# CUDA Configuration (optional)
# Set to specific GPU index if you have multiple GPUs
# -----------------------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# Python Environment
# -----------------------------------------------------------------------------
PYTHONHASHSEED=42

# -----------------------------------------------------------------------------
# API Configuration (for deployment)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Azure Deployment (optional, for cloud deployment)
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=cosmic-net-data

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
